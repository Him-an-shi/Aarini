# Flask Server configuration
PORT=5000
FLASK_ENV=production

# Gemini API configuration
# Paste your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Firebase Admin configuration
# Option A (Local Development): Path to downloaded JSON credential file
# Place the downloaded JSON file in backend/config/serviceAccountKey.json
FIREBASE_CREDENTIALS_PATH=config/serviceAccountKey.json

# Option B (Production/Render): Single-line minified JSON string of serviceAccountKey.json
# Example: {"type": "service_account", "project_id": "your-project", ...}
FIREBASE_SERVICE_ACCOUNT_JSON=YOUR_FIREBASE_SERVICE_ACCOUNT_JSON_HERE
